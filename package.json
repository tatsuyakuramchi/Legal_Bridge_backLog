{
  "name": "legal-bridge-local-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "sample:docs": "tsx scripts/generate-sample-docs.ts",
    "templates:list": "node dist/scripts/template-manager.js list",
    "templates:validate": "node dist/scripts/template-manager.js validate",
    "templates:add": "node dist/scripts/template-manager.js add",
    "templates:backlog-init": "node dist/scripts/template-manager.js backlog-init",
    "templates:backlog-setup": "node dist/scripts/template-manager.js backlog-setup",
    "templates:manage": "node dist/scripts/template-manager.js"
  },
  "dependencies": {
    "@slack/socket-mode": "^2.0.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "handlebars": "^4.7.8",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
