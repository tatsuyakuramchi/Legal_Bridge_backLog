PORT=3005
APP_TITLE=Legal Bridge Local App
BACKLOG_POLLING_INTERVAL_SEC=30

# Backlog
# Example: arclight
BACKLOG_SPACE=
# Project key or numeric project id. Example: LEGAL
BACKLOG_PROJECT_ID=
BACKLOG_API_KEY=

# Slack Socket Mode
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
LEGAL_SLACK_CHANNEL=
# Optional: approver Slack user id
APPROVER_SLACK_ID=

# CloudSign
CLOUDSIGN_CLIENT_ID=
CLOUDSIGN_USE_SANDBOX=false

# RDS / PostgreSQL
RDS_HOST=
RDS_DB=arclight_legal
RDS_USER=legal_app
RDS_PASSWORD=

# Google Drive
# Example: C:\secrets\gws-key.json or /etc/document-service/gws-key.json
GOOGLE_APPLICATION_CREDENTIALS=
DRIVE_ROOT_FOLDER_ID=
