generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["lb_core"]
}

model app_config {
  id         Int      @id @db.SmallInt
  data       Json
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@schema("lb_core")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model contract_alerts {
  id            Int       @id @default(autoincrement())
  contract_id   Int
  alert_type    String    @db.VarChar(50)
  alert_date    DateTime  @db.Date
  sent_at       DateTime  @default(now()) @db.Timestamptz(6)
  slack_channel String?   @db.VarChar(50)
  message_ts    String?   @db.VarChar(50)
  contracts     contracts @relation(fields: [contract_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([contract_id, alert_type, alert_date])
  @@index([contract_id], map: "idx_contract_alerts_contract")
  @@index([alert_type, alert_date], map: "idx_contract_alerts_type_date")
  @@schema("lb_core")
}

model contract_sequences {
  entity_key String   @id @db.VarChar(100)
  sort_index Int      @default(0)
  prefix     String   @db.VarChar(20)
  year       Int
  data       Json
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([prefix, year], map: "idx_contract_sequences_prefix_year")
  @@schema("lb_core")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model contracts {
  id                          Int                 @id @default(autoincrement())
  backlog_issue_id            Int                 @unique
  backlog_issue_key           String              @db.VarChar(20)
  backlog_project_id          Int?
  contract_no                 String              @unique @db.VarChar(30)
  parent_contract_id          Int?
  child_order                 Int?
  is_parent                   Boolean             @default(false)
  child_count                 Int                 @default(0)
  partner_id                  Int?
  counterparty                String              @default("") @db.VarChar(200)
  counterparty_person         String?             @db.VarChar(100)
  contract_type               String              @db.VarChar(50)
  status                      String              @default("草案") @db.VarChar(50)
  status_id                   Int?
  start_date                  DateTime?           @db.Date
  end_date                    DateTime?           @db.Date
  auto_renewal                Boolean             @default(false)
  generation_count            Int                 @default(0)
  last_fixed_at               DateTime?           @db.Timestamptz(6)
  last_fixed_drive_url        String?
  custom_draft_type           String?             @db.VarChar(50)
  custom_draft_drive_url      String?
  custom_draft_base_drive_url String?
  custom_draft_sent_at        DateTime?           @db.Timestamptz(6)
  signing_method              String?             @db.VarChar(20)
  counterparty_ok_at          DateTime?           @db.Timestamptz(6)
  esign_completed_at          DateTime?           @db.Timestamptz(6)
  signed_at                   DateTime?           @db.Timestamptz(6)
  drive_folder_url            String?
  document_origin             String?             @default("internal") @db.VarChar(20)
  external_doc_drive_url      String?
  external_doc_received_at    DateTime?           @db.Date
  is_approver_self            Boolean?            @default(false)
  archived_at                 DateTime?           @db.Timestamptz(6)
  canceled_at                 DateTime?           @db.Timestamptz(6)
  bulk_job_id                 String?             @db.Uuid
  bulk_row_number             Int?
  created_at                  DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime            @default(now()) @db.Timestamptz(6)
  contract_alerts             contract_alerts[]
  contracts                   contracts?          @relation("contractsTocontracts", fields: [parent_contract_id], references: [id], onUpdate: NoAction)
  other_contracts             contracts[]         @relation("contractsTocontracts")
  partners                    partners?           @relation(fields: [partner_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  deliveries                  deliveries[]
  documents                   documents[]
  royalties                   royalties[]
  royalty_schedules           royalty_schedules[]
  sublicenses                 sublicenses[]

  @@index([archived_at], map: "idx_contracts_archived", where: raw("(archived_at IS NULL)"))
  @@index([contract_no], map: "idx_contracts_contract_no")
  @@index([end_date], map: "idx_contracts_end_date")
  @@index([end_date], map: "idx_contracts_end_date_active", where: raw("((archived_at IS NULL) AND (end_date IS NOT NULL))"))
  @@index([backlog_issue_id], map: "idx_contracts_issue_id")
  @@index([backlog_issue_key], map: "idx_contracts_issue_key")
  @@index([parent_contract_id], map: "idx_contracts_parent_id")
  @@index([parent_contract_id, child_order], map: "idx_contracts_parent_order", where: raw("(parent_contract_id IS NOT NULL)"))
  @@index([partner_id], map: "idx_contracts_partner_id")
  @@index([partner_id, signed_at(sort: Desc)], map: "idx_contracts_partner_signed", where: raw("(partner_id IS NOT NULL)"))
  @@index([status], map: "idx_contracts_status")
  @@index([status, updated_at(sort: Desc)], map: "idx_contracts_status_updated", where: raw("(archived_at IS NULL)"))
  @@index([contract_type], map: "idx_contracts_type")
  @@schema("lb_core")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
