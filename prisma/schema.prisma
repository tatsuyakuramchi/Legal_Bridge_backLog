  partial_number      Int?
  total_partials      Int?
  is_final_delivery   Boolean          @default(false)
  drive_url           String?
  inspection_doc_url  String?
  payment_notice_url  String?
  approver_name       String?          @db.VarChar(100)
  approver_department String?          @db.VarChar(100)
  reviewer_name       String?          @db.VarChar(100)
  reviewer_department String?          @db.VarChar(100)
  person_name         String?          @db.VarChar(100)
  person_department   String?          @db.VarChar(100)
  approval_comments   String?
  approved_at         DateTime?        @db.Timestamptz(6)
  notes               String?
  created_at          DateTime         @default(now()) @db.Timestamptz(6)
  updated_at          DateTime         @default(now()) @db.Timestamptz(6)
  contracts           contracts        @relation(fields: [contract_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  delivery_items      delivery_items[]
